// Prisma schema for the Penlabs Lighting Calculator (Prisma 7).
// Connection URLs live in prisma.config.ts (CLI) and are passed to the
// PrismaClient constructor at runtime (accelerateUrl) — not in this file.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  email     String
  phone     String?
  message   String?
  roomName  String?
  source    String? // 'calculator' | 'designer'
  data      Json? // spec snapshot
}

model SharedProject {
  code      String   @id
  editKey   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  client    String?
  data      Json // { rooms, currency }
}
